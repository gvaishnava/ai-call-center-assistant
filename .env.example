# Copy this file to .env and fill in your API keys
# DO NOT commit the actual .env file

OPENAI_API_KEY=sk-...          # Required — get from platform.openai.com
GEMINI_API_KEY=                 # Optional — if using Google Gemini

# Set to 'openai' or 'google'
LLM_PROVIDER=openai

# LangSmith Tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...     # Get from smith.langchain.com
LANGCHAIN_PROJECT="AI Call Center Assistant"
